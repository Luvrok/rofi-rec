#!/usr/bin/env bash

set -euo pipefail

DIR="${HOME}/HOME/screen_recordings"
PIDFILE="/tmp/recpid"
MODEFILE="/tmp/recmode"

FRAMERATE=60
CRF=18
PRESET="ultrafast"

OUTPUT_VOLUME="0.35"
MIC_VOLUME="3.0"

MIC_SOURCE_WPCTL="$(wpctl status | grep -A5 'Settings' | grep -A 5 'Audio/Source' | awk '{print $3}')"
MIC_SOURCE_PACTL="$(pactl get-default-source)"

OUTPUT_SOURCE_WPCTL="$(wpctl status | grep 'Audio/Sink' | awk '{print $3}').monitor"
OUTPUT_SOURCE_PACTL="$(pactl get-default-sink).monitor"

ROFI_CMD=(
  rofi
  -dmenu
  -theme "$HOME/.config/rofi/rofi-rec.rasi"
)

get_mic_source() {
  if command -v pactl >/dev/null 2>&1; then
    printf '%s\n' "$MIC_SOURCE_PACTL"
  elif command -v wpctl >/dev/null 2>&1; then
    printf '%s\n' "$MIC_SOURCE_WPCTL"
  else
    printf '%s\n' "default"
  fi
}

get_output_source() {
  if command -v pactl >/dev/null 2>&1; then
    printf '%s\n' "$OUTPUT_SOURCE_PACTL"
  elif command -v wpctl >/dev/null 2>&1; then
    printf '%s\n' "$OUTPUT_SOURCE_WPCTL"
  else
    printf '%s\n' "default.monitor"
  fi
}

notify() {
  notify-send "Screen recorder" "$1"
}

update_dwmblocks() {
  local signals="1 2"

  if ! command -v pgrep >/dev/null 2>&1 || ! command -v pkill >/dev/null 2>&1; then
    return 0
  fi

  if pgrep -x dwmblocks >/dev/null 2>&1; then
    for signal in $signals; do
      pkill -RTMIN+"$signal" dwmblocks 2>/dev/null || true
    done
  elif pgrep -x dwmblocks-async >/dev/null 2>&1; then
    for signal in $signals; do
      pkill -RTMIN+"$signal" dwmblocks-async 2>/dev/null || true
    done
  fi
}

get_screen_size() {
  xdpyinfo | awk '/dimensions:/ {print $2}'
}

is_recording() {
  [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

stop_recording() {
  if is_recording; then
    kill -2 "$(cat "$PIDFILE")" 2>/dev/null || true
    rm -f "$PIDFILE" "$MODEFILE"
    update_dwmblocks
    notify "Recording ended"
  else
    rm -f "$PIDFILE" "$MODEFILE"
    update_dwmblocks
    notify "No active recording"
  fi
}

start_recording() {
  local mode="$1"
  local screen_size
  local outfile

  mkdir -p "$DIR"
  screen_size="$(get_screen_size)"
  outfile="${DIR}/recording_$(date '+%Y-%m-%d_%H-%M-%S').mkv"

  if is_recording; then
    notify "Recording is already running"
    exit 0
  fi

  notify-send "mic source" "$(get_mic_source)"
  notify-send "output audio source" "$(get_output_source)"

  case "$mode" in
    "screen_only")
      ffmpeg \
        -f x11grab -video_size "$screen_size" -framerate "$FRAMERATE" -i :0.0 \
        -c:v libx264 -preset "$PRESET" -crf "$CRF" \
        "$outfile" \
        >/dev/null 2>&1 &
      ;;
    "screen_mic")
      ffmpeg \
        -f x11grab -video_size "$screen_size" -framerate "$FRAMERATE" -i :0.0 \
        -f pulse -i "$(get_mic_source)" \
        -af "pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}" \
        -c:v libx264 -preset "$PRESET" -crf "$CRF" \
        -c:a aac -b:a 192k \
        "$outfile" \
        >/dev/null 2>&1 &
      ;;
    "screen_output")
      ffmpeg \
        -f x11grab -video_size "$screen_size" -framerate "$FRAMERATE" -i :0.0 \
        -f pulse -i "$(get_output_source)" \
        -af "volume=${OUTPUT_VOLUME}" \
        -c:v libx264 -preset "$PRESET" -crf "$CRF" \
        -c:a aac -b:a 192k \
        "$outfile" \
        >/dev/null 2>&1 &
      ;;
    "screen_mic_output")
      ffmpeg \
        -f x11grab -video_size "$screen_size" -framerate "$FRAMERATE" -i :0.0 \
        -f pulse -i "$(get_output_source)" \
        -f pulse -i "$(get_mic_source)" \
        -filter_complex "[1:a]volume=${OUTPUT_VOLUME}[sys];[2:a]pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}[mic];[sys][mic]amix=inputs=2:normalize=0[aout]" \
        -map 0:v -map "[aout]" \
        -c:v libx264 -preset "$PRESET" -crf "$CRF" \
        -c:a aac -b:a 192k \
        "$outfile" \
        >/dev/null 2>&1 &
      ;;
    *)
      notify "Unknown mode: $mode"
      exit 1
      ;;
  esac

  echo $! > "$PIDFILE"
  echo "$mode" > "$MODEFILE"
  update_dwmblocks
  notify "Recording started: $outfile"
}

menu() {
  printf '%s\n' \
    "Screen + mic + output" \
    "Screen only" \
    "Screen + mic" \
    "Screen + output" \
    "Stop recording" \
  | "${ROFI_CMD[@]}"
}

main() {
  local choice
  choice="$(menu || true)"

  case "$choice" in
    "Screen + mic + output") start_recording "screen_mic_output" ;;
    "Screen only") start_recording "screen_only" ;;
    "Screen + mic") start_recording "screen_mic" ;;
    "Screen + output") start_recording "screen_output" ;;
    "Stop recording") stop_recording ;;
    "") exit 0 ;;
  esac
}

main "$@"
